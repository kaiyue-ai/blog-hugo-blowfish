{
  "installCommand": "",
  "buildCommand": "curl -L https://github.com/gohugoio/hugo/releases/download/v0.161.1/hugo_extended_0.161.1_linux-amd64.tar.gz -o /tmp/hugo.tar.gz && tar -xzf /tmp/hugo.tar.gz -C /tmp && BASE_URL=\"${VERCEL_PROJECT_PRODUCTION_URL:-$VERCEL_URL}\" && BASE_URL=\"${BASE_URL#https://}\" && BASE_URL=\"${BASE_URL#http://}\" && /tmp/hugo --gc --minify --baseURL \"https://${BASE_URL:-blog-hugo-blowfish.vercel.app}\"",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false
}
